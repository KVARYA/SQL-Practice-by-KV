-- fetch 
WITH Ranked AS (
  SELECT empId, name, dept,
         ROW_NUMBER() OVER (
           PARTITION BY empId
           ORDER BY empId
         ) AS rn
  FROM EMPLOYEE
)
DELETE FROM EMPLOYEE
WHERE empId IN (
  SELECT empId FROM Ranked WHERE rn > 1
);
SELECT * FROM EMPLOYEE;



